@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Arzt Von Animal Clinic and Pet Grooming</PageTitle>

<div class="site-shell">
    <div class="clinic-strip"><div class="container header-container"><span class="clinic-strip__desktop">Animal Clinic &amp; Pet Grooming in San Jose del Monte <b>•</b> Est. 2023</span><span class="clinic-strip__mobile">San Jose del Monte <b>•</b> Est. 2023</span></div></div>
    <header class="site-header">
        <div class="container header-container navbar">
            <a class="brand header-brand" href="#home" aria-label="Arzt Von Animal Clinic and Pet Grooming home"><img class="brand__logo" src="images/arzt-von-logo.png" alt="Arzt Von Animal Clinic and Pet Grooming logo" /><span class="brand-copy"><strong>Arzt Von</strong><span>Animal Clinic and Pet Grooming</span><small>Veterinary Care <b>·</b> Pet Grooming <b>·</b> Pet Wellness</small></span></a>
            <nav class="header-actions" aria-label="Clinic quick contact"><a class="header-cta header-cta--facebook" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener"><span class="header-cta__icon" aria-hidden="true">@((MarkupString)MessageIcon)</span><span>Message</span></a><a class="header-cta header-cta--call" href="tel:09363838580"><span class="header-cta__icon" aria-hidden="true">@((MarkupString)PhoneIcon)</span><span>Call</span></a><a class="header-cta header-cta--directions" href="@MapsUrl" target="_blank" rel="noopener"><span class="header-cta__icon" aria-hidden="true">@((MarkupString)LocationIcon)</span><span>Directions</span></a></nav>
        </div>
    </header>

    <nav class="mobile-quick-actions" aria-label="Mobile clinic quick actions"><a class="mobile-quick-action mobile-quick-action--message" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener"><span aria-hidden="true">@((MarkupString)MessageIcon)</span>Message</a><a class="mobile-quick-action mobile-quick-action--call" href="tel:09363838580"><span aria-hidden="true">@((MarkupString)PhoneIcon)</span>Call</a><a class="mobile-quick-action mobile-quick-action--directions" href="@MapsUrl" target="_blank" rel="noopener"><span aria-hidden="true">@((MarkupString)LocationIcon)</span>Directions</a></nav>

    <main>
        <section class="hero" id="home"><div class="container hero__grid">
            <div class="hero__content"><p class="eyebrow">Animal Clinic &amp; Pet Grooming · Est. 2023</p><h1>Veterinary Care and Pet Grooming in San Jose del Monte</h1><p class="hero__lead">Compassionate pet care, grooming, vaccination support, and wellness guidance for dogs and cats.</p><div class="hero__actions"><a class="button" href="#appointment">Request Appointment</a><a class="button button--secondary" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Message</a><a class="button button--secondary" href="@MapsUrl" target="_blank" rel="noopener">Directions</a></div><div class="badge-row"><span>Animal Clinic</span><span>Pet Grooming</span><span>San Jose del Monte</span><span>Est. 2023</span></div></div>
            <div class="hero-visual"><img class="hero-logo" src="images/arzt-von-logo.png" alt="Arzt Von Animal Clinic and Pet Grooming logo" /><div class="media-placeholder media-placeholder--hero" role="img" aria-label="Placeholder for a friendly veterinarian with a dog or cat inside the clinic"><span class="media-placeholder__icon">AV</span><strong>Veterinary care with a gentle touch</strong><small>Clinic photo coming soon</small></div></div>
        </div></section>

        <section class="visit-strip" aria-label="Clinic services"><div class="container visit-strip__grid"><article><span>Care</span><strong>Veterinary support for dogs and cats</strong></article><article><span>Grooming</span><strong>Clean, fresh, comfortable pets</strong></article><article><span>Availability</span><strong>Message or call before visiting</strong></article></div></section>

        <section class="section section--tint services-section" id="services"><div class="container"><div class="section-heading"><div><p class="eyebrow">Our Services</p><h2>Pet Care Services for Dogs and Cats</h2></div><p>Choose the service your pet needs and contact the clinic to confirm schedule and availability.</p></div><div class="service-category-intro"><article><strong>Veterinary Care</strong><p>Consultation, vaccination support, deworming, and basic wellness guidance for your pet.</p></article><article><strong>Pet Grooming</strong><p>Bath, grooming, trimming, and cleaning services to help keep pets fresh and comfortable.</p></article><article><strong>Pet Care Support</strong><p>Helpful guidance for pet owners, follow-up questions, and service availability inquiries.</p></article></div><div class="card-grid service-grid" id="service-cards">
            @foreach (var service in VisibleServices) { <article class="card service-card"><span class="service-category-label">@service.Category</span><span class="card__icon card__icon--svg" aria-hidden="true">@((MarkupString)GetServiceIcon(service.Title))</span><h3>@service.Title</h3><p>@service.Description</p><a class="text-link" href="#appointment">Request This Service →</a></article> }
        </div>@if (AllServices.Length > servicesVisibleCount) { <button class="button button--secondary section-toggle" type="button" aria-controls="service-cards" aria-expanded="@servicesExpanded" @onclick="ToggleServices">@(servicesExpanded ? "Show Less" : "Show More")</button> }</div></section>

        <section class="cta-band"><div class="container"><div class="cta-band__inner"><div><p class="eyebrow">Talk to the Clinic</p><h2>Need help choosing the right service for your pet?</h2><p>Message the clinic to ask about vaccination, grooming, consultation, or current service availability.</p></div><div class="cta-band__actions"><a class="button button--gold" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Message</a><a class="button button--outline-light" href="#appointment">Request Appointment</a></div></div></div></section>

        <section class="section contact-section" id="contact"><div class="container contact-card"><div><p class="eyebrow">Contact Us</p><h2>Get in Touch with the Clinic</h2><p>Message, call, email, or visit the clinic for service inquiries and appointment requests.</p><div class="contact-actions"><a class="button" href="tel:+639363838580">Call 0936 383 8580</a><a class="button button--secondary" href="tel:+639498838572">Call 09498838572</a><a class="button button--secondary" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Message on Facebook</a><a class="button button--secondary" href="mailto:arztvonanimalclinic@gmail.com">Email Clinic</a><a class="button button--secondary" href="@MapsUrl" target="_blank" rel="noopener">Open in Google Maps</a></div></div><address class="contact-details"><span><small>Phone</small><a href="tel:09363838580">0936 383 8580</a><a href="tel:09498838572">0949 883 8572</a></span><span><small>Email</small><a href="mailto:arztvonanimalclinic@gmail.com">arztvonanimalclinic@gmail.com</a></span><span><small>Facebook</small><a href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Arzt Von Animal Clinic and Pet Grooming</a></span><span><small>Address</small><strong>B1 L2 SEI Bldg. Sarmiento Townville, Poblacion 1, San Jose del Monte, Philippines, 3200</strong></span></address></div></section>

        <section class="section" id="updates"><div class="container"><div class="section-heading"><div><p class="eyebrow">Stay Updated</p><h2>Clinic Updates and Pet Care Notices</h2></div><p>Follow the clinic for grooming updates, vaccination reminders, schedule announcements, and helpful pet care tips.</p></div><div class="card-grid updates-grid" id="update-cards">@foreach (var update in GetVisibleItems(Updates, updatesExpanded)) { <article class="card"><span class="card__icon card__icon--svg" aria-hidden="true">@((MarkupString)CalendarIcon)</span><h3>@update</h3><p>Watch our Facebook page for future announcements.</p></article> }</div>@if (ShouldShowToggle(Updates)) { <button class="button button--secondary section-toggle" type="button" aria-controls="update-cards" aria-expanded="@updatesExpanded" @onclick="ToggleUpdates">@(updatesExpanded ? "Show Less" : "Show More")</button> }<a class="button updates-cta" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Visit Facebook Page</a></div></section>

        <section class="section section--tint" id="location"><div class="container location-layout"><div><p class="eyebrow">Visit Our Clinic</p><h2>Find Us in San Jose del Monte</h2><p>Use the map or directions link to easily locate Arzt Von Animal Clinic and Pet Grooming before your visit.</p><p class="address-copy">B1 L2 SEI Bldg. Sarmiento Townville, Poblacion 1, San Jose del Monte, Philippines, 3200</p><div class="hero__actions"><a class="button" href="@MapsUrl" target="_blank" rel="noopener">Open in Google Maps</a><a class="button button--secondary" href="@MapsUrl" target="_blank" rel="noopener">Directions</a></div></div><div class="map-card"><iframe src="@MapsEmbedUrl" title="Google Map showing Arzt Von Animal Clinic and Pet Grooming" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe><a class="button button--secondary" href="@MapsUrl" target="_blank" rel="noopener"><span class="button__icon" aria-hidden="true">@((MarkupString)LocationIcon)</span>Open in Google Maps</a></div></div></section>

        <section class="section grooming-section" id="grooming"><div class="container"><div class="section-heading"><div><p class="eyebrow">Pet Grooming</p><h2>Grooming Care for a Cleaner, Happier Pet</h2></div><p>Help keep your pet clean, comfortable, and well-groomed with caring grooming support.</p></div><div class="card-grid grooming-grid" id="grooming-cards">@foreach (var item in GetVisibleItems(GroomingHighlights, groomingExpanded)) { <article class="grooming-card"><div class="media-placeholder media-placeholder--card" role="img" aria-label="@item pet grooming photo placeholder"><span class="media-placeholder__icon media-placeholder__icon--svg" aria-hidden="true">@((MarkupString)GroomingIcon)</span><strong>Pet Grooming Photo</strong><small>@item image coming soon</small></div><h3>@item</h3></article> }</div>@if (ShouldShowToggle(GroomingHighlights)) { <button class="button button--secondary section-toggle" type="button" aria-controls="grooming-cards" aria-expanded="@groomingExpanded" @onclick="ToggleGrooming">@(groomingExpanded ? "Show Less" : "Show More")</button> }</div></section>

        <section class="section gallery-section" id="gallery"><div class="container"><div class="section-heading"><div><p class="eyebrow">Happy Fur Patients</p><h2>Pet Visits and Grooming Moments</h2></div><p>A gallery space for clinic visits, grooming moments, and happy pets cared for by the clinic.</p></div><div class="filter-row" aria-label="Gallery filters">@foreach (var filter in GalleryFilters) { <button class="filter-button @(galleryFilter == filter ? "is-active" : null)" type="button" @onclick="() => SetGalleryFilter(filter)">@filter</button> }</div><div class="gallery-grid" id="gallery-cards">@foreach (var item in VisibleGalleryItems) { <button class="gallery-card" type="button" @onclick="() => OpenGallery(item)"><div class="media-placeholder media-placeholder--gallery" role="img" aria-label="@item.Caption photo placeholder"><span class="media-placeholder__icon">AV</span><strong>@item.Category Photo</strong><small>Image coming soon</small></div><span><strong>@item.Caption</strong><small>@item.Category</small></span></button> }</div>@if (FilteredGalleryItems.Count > galleryVisibleCount) { <button class="button button--secondary section-toggle" type="button" @onclick="ToggleGallery">@(galleryExpanded ? "Show Less" : "Show More")</button> }</div></section>

        <section class="section" id="reminders"><div class="container"><div class="section-heading section-heading--center"><div><p class="eyebrow">Helpful Guidance</p><h2>Simple Pet Care Reminders</h2><p>Regular checkups, grooming, vaccination, and deworming help support your pet’s overall comfort and wellness.</p></div></div><div class="card-grid reminder-grid" id="reminder-cards">@foreach (var reminder in GetVisibleItems(Reminders, remindersExpanded)) { <article class="card"><h3>@reminder.Title</h3><p>@reminder.Description</p></article> }</div>@if (ShouldShowToggle(Reminders)) { <button class="button button--secondary section-toggle" type="button" aria-controls="reminder-cards" aria-expanded="@remindersExpanded" @onclick="ToggleReminders">@(remindersExpanded ? "Show Less" : "Show More")</button> }</div></section>

        <section class="section section--blue" id="why"><div class="container"><div class="section-heading section-heading--light"><div><p class="eyebrow">Why Choose Us</p><h2>Friendly Local Care for Pets and Pet Owners</h2><p>A local animal clinic and grooming provider focused on clear communication, practical care, and convenient contact options.</p></div></div><div class="card-grid why-grid" id="why-cards">@foreach (var reason in GetVisibleItems(Reasons, reasonsExpanded)) { <article class="card"><span class="card__icon card__icon--svg" aria-hidden="true">@((MarkupString)PawIcon)</span><h3>@reason</h3></article> }</div>@if (ShouldShowToggle(Reasons)) { <button class="button button--secondary section-toggle" type="button" aria-controls="why-cards" aria-expanded="@reasonsExpanded" @onclick="ToggleReasons">@(reasonsExpanded ? "Show Less" : "Show More")</button> }</div></section>

        <section class="section section--soft" id="faq"><div class="container faq-layout"><div><p class="eyebrow">Questions</p><h2>Frequently Asked Questions</h2><p>Quick answers about appointments, grooming, vaccination inquiries, location, and what to prepare before visiting.</p></div><div class="faq-list">@foreach (var item in Faqs) { <details><summary>@item.Question</summary><p>@item.Answer</p></details> }</div></div></section>

        <section class="section veterinarian-section" id="veterinarian"><div class="container veterinarian-layout"><div><p class="eyebrow">About the Veterinary Team</p><h2>Caring Support for Your Pet’s Needs</h2><p class="section-intro">The veterinary team helps pet owners understand their pets’ needs through consultation, wellness support, grooming care, and practical pet care advice.</p><ul class="check-list veterinarian-highlights"><li>Veterinary care for dogs and cats</li><li>Friendly communication with pet owners</li><li>Practical pet health guidance</li><li>Grooming and wellness support in one place</li><li>Local clinic serving San Jose del Monte</li></ul></div><div class="media-placeholder veterinarian-placeholder" role="img" aria-label="Veterinarian caring for a pet at Arzt Von Animal Clinic and Pet Grooming"><span class="media-placeholder__icon" aria-hidden="true">@((MarkupString)PetCareIcon)</span><strong>Veterinarian &amp; Pet Photo</strong><small>Team image coming soon</small></div></div></section>

        <section class="section about-section" id="about"><div class="container split-layout about-card"><div><p class="eyebrow">About the Clinic</p><h2>About Arzt Von Animal Clinic and Pet Grooming</h2><p>A local animal clinic in San Jose del Monte offering veterinary care support and pet grooming services for nearby pet owners.</p><ul class="check-list"><li>Local animal clinic in San Jose del Monte</li><li>Veterinary care and pet grooming in one place</li><li>Friendly support for pet owners</li><li>Easy contact through phone or Facebook Messenger</li></ul></div><div class="media-placeholder media-placeholder--wide" role="img" aria-label="Clinic reception photo placeholder"><span class="media-placeholder__icon">AV</span><strong>Clinic Reception Photo</strong><small>Welcoming clinic image coming soon</small></div></div></section>

        <section class="section" id="appointment"><div class="container appointment-layout"><div><p class="eyebrow">Request an Appointment</p><h2>Send an Appointment Request</h2><p>Tell the clinic about your pet and preferred schedule. The clinic will contact you to confirm availability.</p><p class="appointment-disclaimer">Submitting this form does not confirm your appointment yet. The clinic will contact you to confirm the schedule and service availability.</p><a class="button button--secondary" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Message on Facebook</a></div><form class="appointment-form" id="appointment-form" action="https://api.staticforms.dev/submit" method="post" novalidate><input type="hidden" name="apiKey" value="__STATIC_FORMS_API_KEY__" /><input type="hidden" name="subject" value="Arzt Von appointment request" /><input type="text" name="honeypot" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" /><label>Pet Owner Name<input name="name" required autocomplete="name" /></label><label>Contact Number<input name="phone" type="tel" required autocomplete="tel" /></label><label>Email Address<input name="email" type="email" required autocomplete="email" /></label><label>Pet Name<input name="petName" required /></label><label>Pet Type<select name="petType" required><option value="">Select pet type</option><option>Dog</option><option>Cat</option><option>Other</option></select></label><label>Service Needed<select name="service" required><option value="">Select service</option><option>Vaccination</option><option>Grooming</option><option>Consultation</option><option>Deworming</option><option>Other</option></select></label><label>Preferred Date<input name="preferredDate" type="date" required /></label><label>Preferred Time<input name="preferredTime" type="time" required /></label><label class="full">Message / Pet Concern<textarea name="message" rows="4" required></textarea></label><p class="form-status full" id="form-status" role="status" aria-live="polite"></p><div class="form-actions full"><button class="button" type="submit">Submit Appointment Request</button><a class="button button--secondary" href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener">Message on Facebook</a></div><small class="form-note full">The clinic will contact you to confirm. For urgent concerns, call or message the clinic directly.</small></form></div></section>

    </main>

    <div class="quick-actions" aria-label="Quick actions"><a href="https://www.facebook.com/profile.php?id=100076574323203" target="_blank" rel="noopener" aria-label="Message on Facebook">@((MarkupString)MessageIcon)</a><a href="tel:+639363838580" aria-label="Call the clinic">@((MarkupString)PhoneIcon)</a><a href="@MapsUrl" target="_blank" rel="noopener" aria-label="Get directions">@((MarkupString)LocationIcon)</a><a href="#appointment" aria-label="Request an appointment">@((MarkupString)CalendarIcon)</a></div>

    <footer class="site-footer"><div class="container footer-grid"><div class="footer-brand"><a class="brand brand--footer" href="#home"><img class="footer-logo" src="images/arzt-von-logo.png" alt="Arzt Von logo" /><strong>Arzt Von Animal Clinic and Pet Grooming</strong></a><p>Caring veterinary services and pet grooming for dogs and cats in San Jose del Monte.</p></div><section class="footer-column"><h3>Services</h3><a href="#services">Veterinary Consultation</a><a href="#services">Vaccination</a><a href="#services">Deworming</a><a href="#grooming">Pet Grooming</a></section><address class="footer-column"><h3>Contact</h3><a href="tel:09363838580">0936 383 8580</a><a href="tel:09498838572">0949 883 8572</a><a href="mailto:arztvonanimalclinic@gmail.com">arztvonanimalclinic@gmail.com</a><span>San Jose del Monte, Philippines</span></address></div><div class="container footer-bottom"><span>&copy; 2026 Arzt Von Animal Clinic and Pet Grooming. All rights reserved.</span></div></footer>
</div>

@if (selectedGallery is not null) { <div class="modal-backdrop" role="presentation" @onclick="CloseGallery"><section class="gallery-modal" role="dialog" aria-modal="true" aria-labelledby="gallery-modal-title" @onclick:stopPropagation><header><h2 id="gallery-modal-title">@selectedGallery.Caption</h2><button type="button" aria-label="Close image preview" @onclick="CloseGallery">×</button></header><div class="media-placeholder media-placeholder--modal" role="img" aria-label="Placeholder preview for @selectedGallery.Caption"><span class="media-placeholder__icon">AV</span><strong>@selectedGallery.Caption</strong><small>Real clinic photo coming soon</small></div><footer><small>@selectedGallery.Category · Image placeholder</small></footer></section></div> }

@code {
    private bool servicesExpanded; private bool galleryExpanded; private bool groomingExpanded; private bool updatesExpanded; private bool remindersExpanded; private bool reasonsExpanded; private string galleryFilter = "All"; private GalleryItem? selectedGallery;
    private const string MapsUrl = "https://maps.app.goo.gl/y1J4KdxAvgDh4cKQ9";
    private const string MapsEmbedUrl = "https://maps.google.com/maps?q=B1%20L2%20SEI%20Bldg.%20Sarmiento%20Townville%2C%20Poblacion%201%2C%20San%20Jose%20del%20Monte%2C%20Philippines%2C%203200&t=&z=16&ie=UTF8&iwloc=&output=embed";

    private int servicesVisibleCount = 4; private int galleryVisibleCount = 4; private int defaultVisibleCount = 4; private DotNetObjectReference<Home>? pageReference;
    private IReadOnlyList<GalleryItem> FilteredGalleryItems => galleryFilter == "All" ? GalleryItems : GalleryItems.Where(x => x.Category == galleryFilter).ToArray();
    private IEnumerable<DisplayService> VisibleServices => servicesExpanded ? AllServices : AllServices.Take(servicesVisibleCount);
    private IEnumerable<GalleryItem> VisibleGalleryItems => galleryExpanded ? FilteredGalleryItems : FilteredGalleryItems.Take(galleryVisibleCount);
    private IEnumerable<T> GetVisibleItems<T>(IReadOnlyList<T> items, bool expanded) => expanded ? items : items.Take(defaultVisibleCount);
    private bool ShouldShowToggle<T>(IReadOnlyList<T> items) => items.Count > defaultVisibleCount;
    private void SetGalleryFilter(string filter) { galleryFilter = filter; galleryExpanded = false; }
    private async Task ToggleServices() { servicesExpanded = !servicesExpanded; if (!servicesExpanded) await JS.InvokeVoidAsync("arztVonSite.scrollToSection", "services"); }
    private async Task ToggleGallery() { galleryExpanded = !galleryExpanded; if (!galleryExpanded) await JS.InvokeVoidAsync("arztVonSite.scrollToSection", "gallery"); }
    private Task ToggleGrooming() => ToggleCardSection(nameof(groomingExpanded), "grooming");
    private Task ToggleUpdates() => ToggleCardSection(nameof(updatesExpanded), "updates");
    private Task ToggleReminders() => ToggleCardSection(nameof(remindersExpanded), "reminders");
    private Task ToggleReasons() => ToggleCardSection(nameof(reasonsExpanded), "why");
    private async Task ToggleCardSection(string section, string sectionId)
    {
        var expanded = section switch
        {
            nameof(groomingExpanded) => groomingExpanded = !groomingExpanded,
            nameof(updatesExpanded) => updatesExpanded = !updatesExpanded,
            nameof(remindersExpanded) => remindersExpanded = !remindersExpanded,
            nameof(reasonsExpanded) => reasonsExpanded = !reasonsExpanded,
            _ => false
        };
        if (!expanded) await JS.InvokeVoidAsync("arztVonSite.scrollToSection", sectionId);
    }
    private void OpenGallery(GalleryItem item) => selectedGallery = item; private void CloseGallery() => selectedGallery = null;
    protected override async Task OnAfterRenderAsync(bool firstRender) { if (!firstRender) return; pageReference = DotNetObjectReference.Create(this); await JS.InvokeVoidAsync("arztVonSite.initialize", pageReference); }
    [JSInvokable] public Task UpdateVisibleCounts(int services, int gallery) { servicesVisibleCount = Math.Max(1, services); galleryVisibleCount = Math.Max(1, gallery); defaultVisibleCount = servicesVisibleCount; if (AllServices.Length <= servicesVisibleCount) servicesExpanded = false; if (FilteredGalleryItems.Count <= galleryVisibleCount) galleryExpanded = false; if (!ShouldShowToggle(GroomingHighlights)) groomingExpanded = false; if (!ShouldShowToggle(Updates)) updatesExpanded = false; if (!ShouldShowToggle(Reminders)) remindersExpanded = false; if (!ShouldShowToggle(Reasons)) reasonsExpanded = false; return InvokeAsync(StateHasChanged); }
    public async ValueTask DisposeAsync() { if (pageReference is null) return; try { await JS.InvokeVoidAsync("arztVonSite.dispose"); } catch (JSDisconnectedException) { } pageReference.Dispose(); }
    private static string GetServiceIcon(string title) => title switch { "Pet Vaccination" => ShieldIcon, "Bath and Blow Dry" => DropIcon, "Hair Trimming" or "Nail Trimming" or "Ear Cleaning" or "Grooming Care" => GroomingIcon, _ => PetCareIcon };
    private const string PetCareIcon = """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8.2 10.3c-1.1.5-2.2-.4-2.6-1.5s.1-2.4 1.2-2.7 2.1.6 2.4 1.7.1 2-.9 2.5Zm7.6 0c1.1.5 2.2-.4 2.6-1.5s-.1-2.4-1.2-2.7-2.1.6-2.4 1.7-.1 2 .9 2.5ZM12 18.7c-3.1 0-5.7-1.7-5.7-4.1 0-1.9 1.4-3 3-3.2.8-.1 1.3-.7 1.6-1.3.5-1 1.7-1 2.2 0 .3.6.8 1.2 1.6 1.3 1.6.2 3 1.3 3 3.2 0 2.4-2.6 4.1-5.7 4.1Z"/></svg>""";
    private const string PawIcon = PetCareIcon;
    private const string ShieldIcon = """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8 19 5v5.4c0 4.4-2.9 8.4-7 10.8-4.1-2.4-7-6.4-7-10.8V5l7-2.2Z"/><path class="icon-cut" d="M9 12h6M12 9v6"/></svg>""";
    private const string DropIcon = """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.8S5.5 10.1 5.5 14.4a6.5 6.5 0 0 0 13 0C18.5 10.1 12 2.8 12 2.8Z"/></svg>""";
    private const string GroomingIcon = """<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="6.5" cy="17.5" r="3"/><circle cx="17.5" cy="17.5" r="3"/><path d="m8.8 15.5 8-10.5M15.2 15.5 7.2 5"/></svg>""";
    private const string MessageIcon = """<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4.5h16v11H9l-5 4v-15Z"/></svg>""";
